# ============================================================
# GoodScore AI  –  Environment Variables
# ============================================================

# GLM / Zhipu API key
OPENAI_API_KEY=your-api-key-here

# OpenAI-compatible API Base URL for GLM
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Model Name (e.g. glm-4.5-air, glm-4-flash)
MODEL_NAME=glm-4.5-air

# Database URL
DATABASE_URL=postgresql+asyncpg://support_user:support_pass@postgres:5432/support_ai

# Service URLs
MOCK_API_URL=http://localhost:8001
AI_BACKEND_URL=http://localhost:8000
