# ============================================================
# GoodScore AI  –  Environment Variables
# ============================================================

# Groq API key (or OpenAI API key)
OPENAI_API_KEY=gsk_your_groq_api_key_here

# OpenAI-compatible API Base URL for Groq
OPENAI_API_BASE=https://api.groq.com/openai/v1

# Model Name (e.g. llama-3.3-70b-versatile, llama-3.1-8b-instant)
MODEL_NAME=llama-3.3-70b-versatile

# Database URL
DATABASE_URL=postgresql+asyncpg://support_user:support_pass@postgres:5432/support_ai

# Service URLs
MOCK_API_URL=http://localhost:8001
AI_BACKEND_URL=http://localhost:8000
