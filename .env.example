# ============================================================
# Support AI  –  Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# OpenAI API key (required for ai_backend)
OPENAI_API_KEY=sk-your-key-here

# Database URL (used by mock_api; hostname is the Compose service name)
# For local dev outside Docker, change 'postgres' to 'localhost':
#   DATABASE_URL=postgresql://support_user:support_pass@localhost:5432/support_ai
DATABASE_URL=postgresql+asyncpg://support_user:support_pass@postgres:5432/support_ai

# Service URLs (used when running locally outside Docker)
# Inside Docker, these are overridden by docker-compose.yml environment vars.
MOCK_API_URL=http://localhost:8001
AI_BACKEND_URL=http://localhost:8000
